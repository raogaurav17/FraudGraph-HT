# FraudGraph Backend Environment
# Copy to .env and fill in your values

# App
ENV=development
DEBUG=true

# Redis
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=300

# ML Model
MODEL_PATH=models/htgnn_latest.pt
DEVICE=cpu          # Set to "cuda" if GPU available
BATCH_SIZE=256
MODEL_THRESHOLD=0.5

# Fraud risk thresholds
FRAUD_THRESHOLD_HIGH=0.80
FRAUD_THRESHOLD_MEDIUM=0.50
FRAUD_THRESHOLD_LOW=0.25

# Dataset paths
# Relative paths are resolved from backend/.
DATA_DIR=../data
IEEE_CIS_PATH=../data/ieee_cis
PAYSIM_PATH=../data/paysim
ELLIPTIC_PATH=../data/elliptic
